{
  "name": "scan-react-css",
  "version": "0.1.3",
  "description": "CLI and Node API for auditing React CSS usage.",
  "type": "module",
  "bin": {
    "scan-react-css": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "husky",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "benchmark": "npm run build && node test/performance/benchmark.js",
    "precommit": "npm run format:check && npm run lint && npm run test:coverage:check",
    "test": "npm run build && node --test \"test/unit/**/*.test.js\"",
    "test:coverage": "npm run build && node --test --experimental-test-coverage \"test/unit/**/*.test.js\"",
    "test:coverage:check": "npm run build && node --test --experimental-test-coverage --test-coverage-lines=70 --test-coverage-branches=70 --test-coverage-functions=80 \"test/unit/**/*.test.js\"",
    "prepublishOnly": "npm run check && npm run lint && npm run build"
  },
  "keywords": [
    "react",
    "css",
    "audit",
    "cli",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/georgetupling/scan-react-css.git"
  },
  "homepage": "https://github.com/georgetupling/scan-react-css#readme",
  "bugs": {
    "url": "https://github.com/georgetupling/scan-react-css/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "tsdown": "^0.14.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
